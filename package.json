{
  "private": false,
  "displayName": "Ambient Weather",
  "name": "@bcourbage/homebridge-ambient-weather-sensors",
  "version": "1.5.0-beta.13",
  "description": "Homebridge plugin for Ambient Weather sensors via the AWN REST/websocket API. Soft fork of peledies/homebridge-ambient-weather-sensors with Homebridge 2.x / Node 22+ compatibility, multi-station support, websocket realtime, CO2/PM coverage, and other UX improvements while upstream PRs remain unmerged.",
  "license": "Apache-2.0",
  "author": "Bruno Courbage (https://github.com/bcourbage)",
  "contributors": [
    "Deac Karns (https://github.com/peledies)"
  ],
  "funding": [
    {
      "type": "paypal",
      "url": "https://paypal.me/deackarns"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bcourbage/homebridge-ambient-weather-sensors"
  },
  "bugs": {
    "url": "https://github.com/bcourbage/homebridge-ambient-weather-sensors/issues"
  },
  "homepage": "https://github.com/bcourbage/homebridge-ambient-weather-sensors#readme",
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "build": "node -e \"require('fs').rmSync('./dist',{recursive:true,force:true})\" && node ./node_modules/typescript/bin/tsc",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "ambient-weather",
    "weather-station",
    "homekit",
    "awn",
    "websocket",
    "co2",
    "air-quality",
    "pm2.5"
  ],
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "homebridge": "^2.0.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "volta": {
    "node": "22.12.0"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1"
  }
